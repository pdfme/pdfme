{
  "plugins": ["oxc", "typescript", "unicorn", "react", "vitest"],
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/__image_actual__/**",
    "**/__image_diffs__/**",
    "**/__image_diff_report__/**",
    "website/**"
  ],
  "globals": {
    "window": "readonly",
    "document": "readonly",
    "process": "readonly",
    "vi": "readonly",
    "describe": "readonly",
    "test": "readonly",
    "it": "readonly",
    "expect": "readonly",
    "beforeEach": "readonly",
    "afterEach": "readonly",
    "beforeAll": "readonly",
    "afterAll": "readonly"
  },
  "rules": {
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "warn",
    "react/only-export-components": [
      "warn",
      {
        "allowConstantExport": true
      }
    ]
  },
  "overrides": [
    {
      "files": ["packages/pdf-lib/src/**/*.ts"],
      "rules": {
        "typescript/no-explicit-any": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-return": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-enum-comparison": "off",
        "typescript/no-unsafe-function-type": "off",
        "typescript/restrict-template-expressions": "off",
        "typescript/ban-ts-comment": "off",
        "no-unused-vars": "off",
        "typescript/no-duplicate-enum-values": "off",
        "require-await": "off",
        "typescript/no-empty-object-type": "off",
        "typescript/no-unnecessary-type-assertion": "off",
        "typescript/no-extra-non-null-assertion": "off",
        "typescript/no-wrapper-object-types": "off",
        "no-unused-expressions": "off",
        "typescript/unbound-method": "off",
        "typescript/await-thenable": "off",
        "typescript/prefer-promise-reject-errors": "off",
        "typescript/no-redundant-type-constituents": "off"
      }
    }
  ]
}
