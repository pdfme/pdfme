{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node16",
    "outDir": "./dist/cjs",
    "declaration": true,
    "declarationDir": "dist/types",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "types": ["node", "pdfjs-dist"]
  }
}
