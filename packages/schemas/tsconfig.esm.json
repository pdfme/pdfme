{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node16",
    "outDir": "./dist/esm",
    "declaration": true,
    "declarationDir": "dist/types",
    "skipLibCheck": true,
