{
  "name": "@pdfme/ui",
  "version": "0.0.0",
  "sideEffects": false,
  "author": "hand-dot",
  "license": "MIT",
  "keywords": [
    "pdf",
    "pdf-generation",
    "pdf-designer",
    "pdf-viewer",
    "typescript",
    "react"
  ],
  "description": "TypeScript base PDF generator and React base UI. Open source, developed by the community, and completely free to use under the MIT license!",
  "homepage": "https://pdfme.com",
  "repository": {
    "type": "git",
    "url": "git@github.com:pdfme/pdfme.git"
  },
  "bugs": {
    "url": "https://github.com/pdfme/pdfme/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "run-p devBuild:watch devBuildType:watch",
    "devBuild:watch": "vite build --watch",
    "devBuildType:watch": "tsc -p tsconfig.build.json --watch",
    "build": "vite build && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint --ext .ts,.tsx src --config eslint.config.mjs",
    "test": "vitest run --config ../../vitest.config.ts",
    "prune": "ts-prune src",
    "prettier": "prettier --write 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.0.8",
    "@dnd-kit/sortable": "^10.0.0",
    "@pdfme/converter": "*",
    "@scena/react-guides": "^0.28.2",
    "antd": "^5.27.4",
    "dompurify": "^3.3.3",
    "form-render": "^2.5.5",
    "globrex": "^0.1.2",
    "hotkeys-js": "^4.0.2",
    "lucide-react": "^0.577.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-moveable": "^0.56.0",
    "react-refresh": "^0.18.0",
    "react-selecto": "^1.12.0"
  },
  "devDependencies": {
    "@pdfme/common": "*",
    "@pdfme/schemas": "*",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^12.1.2",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^17.0.52",
    "@types/react-dom": "^17.0.18",
    "@ungap/structured-clone": "^1.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "csstype": "^3.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "is-path-inside": "^4.0.0",
    "jest-canvas-mock": "^2.3.1",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "process": "^0.11.10",
    "rollup": "^4.59.0",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "peerDependencies": {
    "@pdfme/common": "latest",
    "@pdfme/schemas": "latest"
  },
  "publishConfig": {
    "access": "public"
  }
}
