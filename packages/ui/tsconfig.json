{
  "compilerOptions": {
    "jsx": "react",
    "declaration": true,
    "declarationDir": "dist/types",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "target": "ES2020",
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["jest"],
    "typeRoots": ["../node_modules/@types", "./node_modules/@types", "../../node_modules/@types"],
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@pdfme/common": ["../common/dist/esm/src"],
      "@pdfme/schemas": ["../schemas/dist/esm/src"],
      "@pdfme/schemas/utils": ["../schemas/dist/esm/src/utils"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
