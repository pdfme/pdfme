{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "jsx": "react",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": ["jest"],
    "typeRoots": ["../node_modules/@types", "./node_modules/@types", "../../node_modules/@types"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
